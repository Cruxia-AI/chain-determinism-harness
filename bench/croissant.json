  "@type": "sc:Dataset",
  "name": "chain-determinism-bench-v1",
  "description": "Multi-vendor chain-determinism observations from 22,000+ replayed agent runs across 11 LLMs. Per-run rows include prompt text (synthetic Sigma-registry queries) plus SHA-256 hashes for response, tool-call sequence, and final answer. Hash format is byte-identical to chain-receipt-sdk so each row can be replayed via `chain-receipt replay <hash>`. Released alongside the Chain-Divergence paper (Cruxia-AI, under peer review).",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "url": "https://github.com/Cruxia-AI/chain-determinism-harness/tree/main/bench",
  "version": "0.1.0",
  "keywords": [
    "chain-determinism",
    "agent reproducibility",
    "LLM evaluation",
    "audit trail",
    "EU AI Act",
    "tool-calling agents"
  ],
  "creator": {
    "@type": "Person",
    "name": "Mars Ausili",
    "affiliation": "Cruxia-AI"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Cruxia"
  },
  "citeAs": "@unpublished{ausili2026chaindivergence, title={Chain-Divergence: A Cross-Vendor Benchmark and Mechanism Probe for Replay-Attestable LLM Agents}, author={Ausili, Mars}, year={2026}, note={Under peer review. See https://chain-determinism.org/paper for current status.}}",
  "datePublished": "2026-04-27",
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "phase_1a_file",
      "name": "phase_1a.jsonl",
      "description": "Phase 1a: T=0.0 multi-vendor replay (11 models x 40 held-out OOD queries x 50 runs = 22,000 rows).",
      "contentUrl": "data/phase_1a.jsonl",
      "encodingFormat": "application/jsonl",
      "sha256": "edb6e91bea4fbf04273da15870ddd82535794d213a21b0ec24a23ab9f06711e4"
    },
    {
      "@type": "cr:FileObject",
      "@id": "phase_1b_file",
      "name": "phase_1b.jsonl",
      "description": "Phase 1b: T=0.5/1.0 temperature sweep (10 models x 40 queries x 20 runs x 2 temps = 8,000 rows; one model dropped from 1b run).",
      "contentUrl": "data/phase_1b.jsonl",
      "encodingFormat": "application/jsonl",
      "sha256": "3a6c4093e4a9b810d2f42a940dc7367ef6507e016745a48a10336220300abd0b"
    },
    {
      "@type": "cr:FileObject",
      "@id": "phase_2_v2_file",
      "name": "phase_2_v2.jsonl",
      "description": "Phase 2 v2: mechanism attribution on Qwen 2.5 72B Instruct (Modal vLLM A100-80GB:2). 1,600 hash-only Receipts: 40 held-out queries x 20 replays x 2 toggles (baseline_all_on, batch_invariant_proxy). baseline_all_on chain-divergence 27.5% [Wilson 95% CI 16.1%, 42.8%]; batch_invariant_proxy 0.0% [0.0%, 8.8%]; McNemar exact-binomial two-sided p = 0.000977.",
      "contentUrl": "data/phase_2_v2.jsonl",
      "encodingFormat": "application/jsonl",
      "sha256": "e7009813f28e0f47b399dba8c982f693052b9f6cb52648c9019924128c0b9ee5"
    },
    {
